\ProvidesPackage{listofanswers}[06/11/2012]

\newcounter{group}
\newcounter{exercise}[group]
\newcounter{subexercise}[exercise]

% Flag: compact subexercise rendering (set by \exercise*)
\newif\if@compactexercise
\@compactexercisefalse

% --- Group (one per chapter) -------------------------------------------
\newcommand{\group}{%
  \refstepcounter{group}
  \addcontentsline{loa}{group}{\thegroup}
}

% --- Exercise -----------------------------------------------------------
\newcommand{\exercise}{%
  \refstepcounter{exercise}
  \@ifstar\exerciseStar\exerciseNoStar
}

\newcommand{\exerciseNoStar}[1]{%
  \@ifnextchar\bgroup{\exerciseNoStarTwo{#1}}{\exerciseNoStarOne{#1}}
}

% Exercise without answer — still writes a heading entry
\newcommand{\exerciseNoStarOne}[1]{%
  \@compactexercisefalse
  \textbf{Ejercicio~\theexercise.} #1
  \addcontentsline{loa}{exercise}{\theexercise}
}

% Exercise with answer — writes heading entry + answer entry
\newcommand{\exerciseNoStarTwo}[2]{%
  \@compactexercisefalse
  \textbf{Ejercicio~\theexercise.} #1
  \addcontentsline{loa}{exercise}{\theexercise}
  \addcontentsline{loa}{exerciseanswer}{#2}
}

% Starred exercise — compact mode: subexercise answers rendered inline
\newcommand{\exerciseStar}[1]{%
  \@compactexercisetrue
  \textbf{Ejercicio~\theexercise.} #1
  \addcontentsline{loa}{exercise}{\theexercise}
}

% --- Subexercise --------------------------------------------------------
\newcommand{\subexercise}[1]{%
  \refstepcounter{subexercise}
  \@ifnextchar\bgroup{\subexerciseTwo{#1}}{\subexerciseOne{#1}}
}

\newcommand{\subexerciseOne}[1]{%
\@alph\thesubexercise) #1
}

\newcommand{\subexerciseTwo}[2]{%
\@alph\thesubexercise)~#1
\if@compactexercise
\addcontentsline{loa}{subexercisecompact}{%
\@alph\thesubexercise)~#2%
}
\else
\addcontentsline{loa}{subexercise}{%
\@alph\thesubexercise)~#2%
}
\fi
}

% --- Rendering in the answers chapter -----------------------------------
% \l@group: section heading
\newcommand*{\l@group}[2]{%
\section*{Ejercicios del capítulo~#1}%
}

% \l@exercise: subsection heading
\newcommand*{\l@exercise}[2]{%
\subsection*{Ejercicio~#1}%
}

% \l@exerciseanswer: answer paragraph (for exercises with direct answer)
\newcommand*{\l@exerciseanswer}[2]{%
\noindent\small #1\par
}

% \l@subexercise: answer paragraph with letter prefix
\newcommand*{\l@subexercise}[2]{%
\noindent #1\par\smallskip
}

% \l@subexercisecompact: inline answer (\exercise* mode)
\newcommand*{\l@subexercisecompact}[2]{%
#1\hskip 1em plus .3em minus .3em
}

% --- Entry point --------------------------------------------------------
\newcommand{\listofanswers}{%
\answershead
\@starttoc{loa}
\addcontentsline{toc}{\answerstype}{\answersname}
}

\@ifclassloaded{book}
{\newcommand{\answershead}{
\chapter*{\answersname}}
\newcommand{\answerstype}{chapter}}
{\newcommand{\answershead}{
\section*{\answersname}}
\newcommand{\answerstype}{section}}

\newcommand{\answersname}{Respuestas}
\newcommand{\exercisesname}{Ejercicios}
\newcommand{\groupname}{Grupo}
