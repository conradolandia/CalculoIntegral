\ProvidesPackage{listofanswers}[17/04/2026]

\newcounter{group}
\newcounter{exercise}[group]
\newcounter{subexercise}[exercise]

% Bandera: modo compacto para subejercicio (activado por \exercise*)
\newif\if@compactexercise
\@compactexercisefalse

% Anchos de sangría colgante (ancho del cuadro de etiqueta = sangría del párrafo)
\newlength{\loa@exindent}
\setlength{\loa@exindent}{2em}      % suficiente para "30)"
\newlength{\loa@subexindent}
\setlength{\loa@subexindent}{1.5em} % suficiente para "a)" … "z)"

% Auxiliar interno: un párrafo con sangría colgante
% #1 = etiqueta  #2 = ancho de colgado  #3 = desplazamiento del margen izquierdo  #4 = cuerpo
\newcommand{\loa@hangitem}[4]{%
  \par
  \leftskip=#3\relax
  \noindent
  \hangindent=#2\hangafter=1%
  \makebox[#2][l]{#1}#4\par
  \leftskip=\z@
}

% --- Grupo (uno por capítulo) ------------------------------------------
\newcommand{\group}{%
  \refstepcounter{group}
  \addcontentsline{loa}{group}{\thegroup}
}

% --- Ejercicio ----------------------------------------------------------
\newcommand{\exercise}{%
  \refstepcounter{exercise}
  \@ifstar\exerciseStar\exerciseNoStar
}

\newcommand{\exerciseNoStar}[1]{%
  \@ifnextchar\bgroup{\exerciseNoStarTwo{#1}}{\exerciseNoStarOne{#1}}
}

% Ejercicio sin respuesta — igualmente escribe una entrada de encabezado
\newcommand{\exerciseNoStarOne}[1]{%
  \@compactexercisefalse
\loa@hangitem{\theexercise)}{\loa@exindent}{\z@}{#1}%
\addcontentsline{loa}{exercise}{\theexercise}%
}

% Ejercicio con respuesta — escribe entrada de encabezado + entrada de respuesta
\newcommand{\exerciseNoStarTwo}[2]{%
\@compactexercisefalse
\loa@hangitem{\theexercise)}{\loa@exindent}{\z@}{#1}%
\addcontentsline{loa}{exercise}{\theexercise}%
\addcontentsline{loa}{exerciseanswer}{#2}%
}

% Ejercicio con asterisco — modo compacto: respuestas de subejercicio renderizadas en línea
\newcommand{\exerciseStar}[1]{%
\@compactexercisetrue
\loa@hangitem{\theexercise)}{\loa@exindent}{\z@}{#1}%
\addcontentsline{loa}{exercise}{\theexercise}%
}

% --- Subejercicio -------------------------------------------------------
\newcommand{\subexercise}[1]{%
\refstepcounter{subexercise}
\@ifnextchar\bgroup{\subexerciseTwo{#1}}{\subexerciseOne{#1}}
}

\newcommand{\subexerciseOne}[1]{%
\loa@hangitem{\@alph\thesubexercise)}{\loa@subexindent}{\loa@exindent}{#1}%
}

\newcommand{\subexerciseTwo}[2]{%
\loa@hangitem{\@alph\thesubexercise)}{\loa@subexindent}{\loa@exindent}{#1}%
\if@compactexercise
\addcontentsline{loa}{subexercisecompact}{%
\@alph\thesubexercise)\hspace{0.5em}#2}%
\else
\addcontentsline{loa}{subexercise}{%
\@alph\thesubexercise)\hspace{0.5em}#2}%
\fi
}

% --- Renderizado en el capítulo de respuestas --------------------------
% \l@group: encabezado de sección
\newcommand*{\l@group}[2]{%
\section*{Ejercicios del capítulo~#1}%
}

% \l@exercise: encabezado de subsección
\newcommand*{\l@exercise}[2]{%
\subsection*{Ejercicio~#1}%
}

% \l@exerciseanswer: párrafo de respuesta (para ejercicios con respuesta directa)
\newcommand*{\l@exerciseanswer}[2]{%
\noindent\small #1\par
}

% \l@subexercise: párrafo de respuesta con prefijo de letra
\newcommand*{\l@subexercise}[2]{%
\noindent #1\par\smallskip
}

% \l@subexercisecompact: respuesta en línea (modo \exercise*)
\newcommand*{\l@subexercisecompact}[2]{%
#1\hskip 1em plus .3em minus .3em
}

% --- Punto de entrada ---------------------------------------------------
\newcommand{\listofanswers}{%
\answershead
\addcontentsline{toc}{\answerstype}{\answersname}
\@starttoc{loa}
}

\@ifclassloaded{book}
{\newcommand{\answershead}{
\chapter*{\answersname}}
\newcommand{\answerstype}{chapter}}
{\newcommand{\answershead}{
\section*{\answersname}}
\newcommand{\answerstype}{section}}

\newcommand{\answersname}{Respuestas a los ejercicios}
\newcommand{\exercisesname}{Ejercicios}
\newcommand{\groupname}{Grupo}
